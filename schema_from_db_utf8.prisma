  updatedAt      DateTime         @updatedAt @map("updated_at")
  page           AboutCountryPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@map("country_tourist_attractions")
}

model StudyMode {
  id        Int      @id @default(autoincrement())
  studyMode String   @map("study_mode")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("study_modes")
}

model ExpertTeam {
  id          Int      @id @default(autoincrement())
  name        String
  designation String?
  description String?
  photoName   String?  @map("photo_name")
  photoPath   String?  @map("photo_path")
  linkedinUrl String?  @map("linkedin_url")
  position    Int      @default(1)
  status      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("expert_teams")
}

model EducationSystemPage {
  id          Int      @id @default(autoincrement())
  title       String
  subtitle    String?
  description String?
  highlights  Json?
  iconClass   String?  @map("icon_class")
  position    Int      @default(1)
  status      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("education_system_pages")
}

