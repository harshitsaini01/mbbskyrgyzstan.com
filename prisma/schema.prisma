// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────

enum UserRole {
  admin
  employee
  agent
  student
}

enum LeadStatus {
  active
  inactive
  blocked
}

enum NeetStatus {
  qualified
  not_qualified
}

enum ApplicationStatus {
  applied
  shortlisted
  accepted
  rejected
}

// ─────────────────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────────────────

model User {
  id              Int       @id @default(autoincrement())
  name            String
  email           String    @unique
  emailVerifiedAt DateTime? @map("email_verified_at")
  password        String
  role            UserRole  @default(employee)
  phone           String?
  photoName       String?   @map("photo_name")
  photoPath       String?   @map("photo_path")
  designation     String?
  description     String?   @db.Text
  rememberToken   String?   @map("remember_token")
  status          Boolean   @default(true)
  otp             String?   @db.VarChar(6)
  otpExpireAt     DateTime? @map("otp_expire_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  blogs                  Blog[]
  news                   News[]
  referrals              LeadInquiry[]
  articles               Article[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────
// REFERENCE DATA
// ─────────────────────────────────────────────────────────

model InstituteType {
  id           Int          @id @default(autoincrement())
  name         String
  status       Boolean      @default(true)
  universities University[]

  @@map("institute_types")
}

model Province {
  id         Int          @id @default(autoincrement())
  name       String
  status     Boolean      @default(true)
  cities     City[]
  universities University[]

  @@map("provinces")
}

model City {
  id           Int          @id @default(autoincrement())
  name         String
  provinceId   Int          @map("province_id")
  province     Province     @relation(fields: [provinceId], references: [id])
  status       Boolean      @default(true)
  universities University[]

  @@map("cities")
}

model Level {
  id                  Int                  @id @default(autoincrement())
  name                String
  slug                String               @unique
  description         String?              @db.Text
  status              Boolean              @default(true)
  universityPrograms  UniversityProgram[]

  @@map("levels")
}

model Facility {
  id                    Int                    @id @default(autoincrement())
  name                  String
  iconName              String?                @map("icon_name")
  iconPath              String?                @map("icon_path")
  status                Boolean                @default(true)
  universityFacilities  UniversityFacility[]

  @@map("facilities")
}

model Hospital {
  id                   Int                   @id @default(autoincrement())
  name                 String
  slug                 String                @unique
  city                 String?
  state                String?
  beds                 Int?
  establishedYear      Int?                  @map("established_year")
  accreditation        String?
  imageName            String?               @map("image_name")
  imagePath            String?               @map("image_path")
  status               Boolean               @default(true)
  universityHospitals  UniversityHospital[]

  @@map("hospitals")
}

// ─────────────────────────────────────────────────────────
// UNIVERSITIES (14 related tables)
// ─────────────────────────────────────────────────────────

model University {
  id                      Int       @id @default(autoincrement())
  name                    String
  slug                    String    @unique
  thumbnailName           String?   @map("thumbnail_name")
  thumbnailPath           String?   @map("thumbnail_path")
  bannerName              String?   @map("banner_name")
  bannerPath              String?   @map("banner_path")
  brochureName            String?   @map("brochure_name")
  brochurePath            String?   @map("brochure_path")
  embassyLetterPath       String?   @map("embassy_letter_path")
  universityLicensePath   String?   @map("university_license_path")
  aggregationLetterPath   String?   @map("aggregation_letter_path")
  nmcGuidelinesPath       String?   @map("nmc_guidelines_path")
  isFeatured              Boolean   @default(false) @map("is_featured")
  city                    String?
  state                   String?
  rating                  Decimal?  @db.Decimal(3, 2)
  establishedYear         Int?      @map("established_year")
  scholarshipName         String?   @map("scholarship_name")
  scholarshipAmount       String?   @map("scholarship_amount") @db.VarChar(50)
  seatsAvailable          Int?      @map("seats_available")
  students                String?
  tuitionFee              Decimal?  @map("tuition_fee") @db.Decimal(12, 2)
  approvedBy              Json?     @map("approved_by")
  shortnote               String?   @db.Text
  fmgePassRate            Decimal?  @map("fmge_pass_rate") @db.Decimal(5, 2)
  courseDuration          String?   @map("course_duration")
  mediumOfInstruction     String?   @map("medium_of_instruction")
  eligibility             String?
  neetRequirement         String?   @map("neet_requirement")
  aboutNote               String?   @map("about_note") @db.Text
  internationalRecognition String?  @map("international_recognition") @db.VarChar(50)
  englishMedium           String?   @map("english_medium") @db.VarChar(50)
  diverseCommunity        String?   @map("diverse_community") @db.VarChar(50)
  section2Image           String?   @map("section2_image")
  section2Title           String?   @map("section2_title")
  section2Text            String?   @map("section2_text") @db.Text
  yearOfExcellence        Int?      @map("year_of_excellence")
  countriesRepresented    Int?      @map("countries_represented")
  globalRanking           String?   @map("global_ranking")
  campusArea              String?   @map("campus_area")
  labs                    Int?
  lectureHall             Int?      @map("lecture_hall")
  hostelBuilding          Int?      @map("hostel_building")
  parentSatisfaction      Decimal?  @map("parent_satisfaction") @db.Decimal(5, 2)
  totalReviews            Int?      @map("total_reviews")
  recommendedRate         Decimal?  @map("recommended_rate") @db.Decimal(5, 2)
  embassyVerified         Boolean   @default(false) @map("embassy_verified")
  whoListed               Boolean   @default(false) @map("who_listed")
  nmcApproved             Boolean   @default(false) @map("nmc_approved")
  ministryLicensed        Boolean   @default(false) @map("ministry_licensed")
  faimerListed            Boolean   @default(false) @map("faimer_listed")
  mciRecognition          Boolean   @default(false) @map("mci_recognition")
  ecfmgEligible           Boolean   @default(false) @map("ecfmg_eligible")
  applyNowUrl             String?   @map("apply_now_url") @db.Text
  status                  Boolean   @default(true)
  homeView                Boolean   @default(false) @map("home_view")
  instituteTypeId         Int?      @map("institute_type_id")
  provinceId              Int?      @map("province_id")
  cityId                  Int?      @map("city_id")
  createdBy               Int?      @map("created_by")
  updatedBy               Int?      @map("updated_by")
  metaTitle               String?   @map("meta_title") @db.Text
  metaKeyword             String?   @map("meta_keyword") @db.Text
  metaDescription         String?   @map("meta_description") @db.Text
  ogImagePath             String?   @map("og_image_path") @db.Text
  seoRating               Decimal?  @map("seo_rating") @db.Decimal(2, 1)
  reviewNumber            Int?      @map("review_number")
  bestRating              Decimal?  @map("best_rating") @db.Decimal(2, 1)
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  instituteType     InstituteType?          @relation(fields: [instituteTypeId], references: [id])
  province          Province?               @relation(fields: [provinceId], references: [id])
  cityRelation      City?                   @relation(fields: [cityId], references: [id])
  programs          UniversityProgram[]
  photos            UniversityPhoto[]
  rankings          UniversityRanking[]
  studentRecords    UniversityStudent[]
  fmgeRates         UniversityFmgeRate[]
  intakes           UniversityIntake[]
  testimonials      UniversityTestimonial[]
  reviews           UniversityReview[]
  faqs              UniversityFaq[]
  facilities        UniversityFacility[]
  hospitals         UniversityHospital[]
  links             UniversityLink[]
  scholarships      Scholarship[]

  @@map("universities")
}

model UniversityProgram {
  id                    Int       @id @default(autoincrement())
  programName           String    @map("program_name")
  programSlug           String    @map("program_slug")
  duration              String?
  levelId               Int?      @map("level_id")
  studyMode             String?   @map("study_mode") @db.Text
  totalFee              Decimal?  @map("total_fee") @db.Decimal(12, 2)
  totalTuitionFee       Decimal?  @map("total_tuition_fee") @db.Decimal(12, 2)
  annualTuitionFee      Decimal?  @map("annual_tuition_fee") @db.Decimal(12, 2)
  currency              String    @default("INR") @db.VarChar(10)
  applicationDeadline   String?   @map("application_deadline")
  intake                String?   @db.Text
  isActive              Boolean   @default(true) @map("is_active")
  sortOrder             Int       @default(1) @map("sort_order")
  overview              String?   @db.Text
  eligibility           String?   @db.Text
  mediumOfInstruction   String?   @map("medium_of_instruction")
  recognition           String?
  whyChooseVietnam      String?   @map("why_choose_vietnam") @db.Text
  additionalInformation String?   @map("additional_information") @db.Text
  year1Syllabus         String?   @map("year1_syllabus") @db.Text
  year2Syllabus         String?   @map("year2_syllabus") @db.Text
  year3Syllabus         String?   @map("year3_syllabus") @db.Text
  year4Syllabus         String?   @map("year4_syllabus") @db.Text
  year5Syllabus         String?   @map("year5_syllabus") @db.Text
  year6Syllabus         String?   @map("year6_syllabus") @db.Text
  universityId          Int       @map("university_id")
  metaTitle             String?   @map("meta_title") @db.Text
  metaKeyword           String?   @map("meta_keyword") @db.Text
  metaDescription       String?   @map("meta_description") @db.Text
  ogImagePath           String?   @map("og_image_path") @db.Text
  seoRating             Decimal?  @map("seo_rating") @db.Decimal(2, 1)
  reviewNumber          Int?      @map("review_number")
  bestRating            Decimal?  @map("best_rating") @db.Decimal(2, 1)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  level        Level?     @relation(fields: [levelId], references: [id])
  applications StudentApplication[]

  @@map("university_programs")
}

model UniversityPhoto {
  id           Int        @id @default(autoincrement())
  title        String?
  imageName    String?    @map("image_name")
  imagePath    String?    @map("image_path")
  position     Int        @default(1)
  status       Boolean    @default(true)
  universityId Int        @map("university_id")
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("university_photos")
}

model UniversityRanking {
  id            Int        @id @default(autoincrement())
  rankingBody   String     @map("ranking_body")
  rank          String?
  year          Int?
  category      String?
  score         Decimal?   @db.Decimal(5, 2)
  position      Int        @default(1)
  status        Boolean    @default(true)
  universityId  Int        @map("university_id")
  university    University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@map("university_rankings")
}

model UniversityStudent {
  id                Int        @id @default(autoincrement())
  name              String?
  email             String?
  phone             String?
  country           String?
  countryIsoCode    String?    @map("country_iso_code") @db.VarChar(5)
  numberOfStudents  Int?       @map("number_of_students")
  course            String?
  year              String?
  imageName         String?    @map("image_name")
  imagePath         String?    @map("image_path")
  status            Boolean    @default(true)
  universityId      Int        @map("university_id")
  university        University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  @@map("university_students")
}

model UniversityFmgeRate {
  id                   Int        @id @default(autoincrement())
  year                 Int
  appeared             Int?
  passed               Int?
  passPercentage       Decimal?   @map("pass_percentage") @db.Decimal(5, 2)
  acceptanceRate       Decimal?   @map("acceptance_rate") @db.Decimal(5, 2)
  yoyChange            String?    @map("yoy_change") @db.VarChar(20)
  firstAttemptPassRate Decimal?   @map("first_attempt_pass_rate") @db.Decimal(5, 2)
  rank                 Int?
  notes                String?    @db.Text
  source               String?
  position             Int        @default(1)
  status               Boolean    @default(true)
  universityId         Int        @map("university_id")
  university           University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  @@map("university_fmge_rates")
}

model UniversityIntake {
  id                   Int        @id @default(autoincrement())
  intakeMonth          String     @map("intake_month")
  intakeYear           Int        @map("intake_year")
  applicationStart     DateTime?  @map("application_start") @db.Date
  applicationDeadline  DateTime?  @map("application_deadline") @db.Date
  classesStart         DateTime?  @map("classes_start") @db.Date
  seats                Int?
  statusText           String?    @map("status_text")
  notes                String?    @db.Text
  position             Int        @default(1)
  isActive             Boolean    @default(true) @map("is_active")
  universityId         Int        @map("university_id")
  university           University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  @@map("university_intakes")
}

model UniversityTestimonial {
  id           Int        @id @default(autoincrement())
  name         String
  designation  String?
  country      String?
  course       String?
  year         String?
  description  String?    @db.Text
  rating       Decimal?   @db.Decimal(2, 1)
  imageName    String?    @map("image_name")
  imagePath    String?    @map("image_path")
  videoUrl     String?    @map("video_url")
  position     Int        @default(1)
  status       Boolean    @default(true)
  universityId Int        @map("university_id")
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("university_testimonials")
}

model UniversityReview {
  id           Int        @id @default(autoincrement())
  name         String
  designation  String?
  country      String?
  course       String?
  year         String?
  description  String?    @db.Text
  rating       Decimal?   @db.Decimal(2, 1)
  imageName    String?    @map("image_name")
  imagePath    String?    @map("image_path")
  position     Int        @default(1)
  status       Boolean    @default(true)
  universityId Int        @map("university_id")
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("university_reviews")
}

model UniversityFaq {
  id           Int        @id @default(autoincrement())
  question     String     @db.Text
  answer       String     @db.Text
  position     Int        @default(1)
  status       Boolean    @default(true)
  universityId Int        @map("university_id")
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("university_faqs")
}

model UniversityFacility {
  id           Int        @id @default(autoincrement())
  universityId Int        @map("university_id")
  facilityId   Int        @map("facility_id")
  description  String?    @db.Text
  imageName    String?    @map("image_name")
  imagePath    String?    @map("image_path")
  status       Boolean    @default(true)
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  facility     Facility   @relation(fields: [facilityId], references: [id])
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("university_facilities")
}

model UniversityHospital {
  id           Int        @id @default(autoincrement())
  universityId Int        @map("university_id")
  hospitalId   Int        @map("hospital_id")
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  hospital     Hospital   @relation(fields: [hospitalId], references: [id])
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("university_hospitals")
}

model UniversityLink {
  id           Int        @id @default(autoincrement())
  title        String
  url          String
  type         String?
  position     Int        @default(1)
  status       Boolean    @default(true)
  universityId Int        @map("university_id")
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("university_links")
}

// ─────────────────────────────────────────────────────────
// SCHOLARSHIPS
// ─────────────────────────────────────────────────────────

model Scholarship {
  id                 Int       @id @default(autoincrement())
  title              String
  slug               String    @unique
  scholarshipType    String?   @map("scholarship_type")
  amountMin          Decimal?  @map("amount_min") @db.Decimal(10, 2)
  amountMax          Decimal?  @map("amount_max") @db.Decimal(10, 2)
  discountPercentage Int?      @map("discount_percentage")
  deadline           DateTime? @db.Date
  availableSeats     Int?      @map("available_seats")
  program            String?
  applicationMode    String?   @map("application_mode")
  eligibility        Json?
  coverage           Json?
  shortnote          String?   @db.Text
  isActive           Boolean   @default(true) @map("is_active")
  universityId       Int?      @map("university_id")
  metaTitle          String?   @map("meta_title") @db.Text
  metaKeyword        String?   @map("meta_keyword") @db.Text
  metaDescription    String?   @map("meta_description") @db.Text
  ogImagePath        String?   @map("og_image_path") @db.Text
  seoRating          Decimal?  @map("seo_rating") @db.Decimal(2, 1)
  reviewNumber       Int?      @map("review_number")
  bestRating         Decimal?  @map("best_rating") @db.Decimal(2, 1)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  university University?   @relation(fields: [universityId], references: [id], onDelete: Cascade)
  faqs       ScholarshipFaq[]

  @@map("scholarships")
}

model ScholarshipFaq {
  id            Int         @id @default(autoincrement())
  question      String      @db.Text
  answer        String      @db.Text
  position      Int         @default(1)
  status        Boolean     @default(true)
  scholarshipId Int         @map("scholarship_id")
  scholarship   Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("scholarship_faqs")
}

// ─────────────────────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────────────────────

model BlogCategory {
  id              Int      @id @default(autoincrement())
  name            String
  slug            String   @unique
  description     String?  @db.Text
  imageName       String?  @map("image_name")
  imagePath       String?  @map("image_path")
  status          Boolean  @default(true)
  metaTitle       String?  @map("meta_title") @db.Text
  metaKeyword     String?  @map("meta_keyword") @db.Text
  metaDescription String?  @map("meta_description") @db.Text
  ogImagePath     String?  @map("og_image_path") @db.Text
  seoRating       Decimal? @map("seo_rating") @db.Decimal(2, 1)
  reviewNumber    Int?     @map("review_number")
  bestRating      Decimal? @map("best_rating") @db.Decimal(2, 1)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  blogs           Blog[]

  @@map("blog_categories")
}

model Blog {
  id              Int          @id @default(autoincrement())
  categoryId      Int          @map("category_id")
  authorId        Int          @map("author_id")
  title           String?      @db.Text
  slug            String?      @db.Text
  shortnote       String?      @db.Text
  description     String?      @db.Text
  thumbnailName   String?      @map("thumbnail_name") @db.VarChar(200)
  thumbnailPath   String?      @map("thumbnail_path") @db.Text
  imageName       String?      @map("image_name") @db.VarChar(200)
  imagePath       String?      @map("image_path") @db.Text
  status          Boolean      @default(true)
  homeView        Boolean      @default(false) @map("home_view")
  trending        Boolean      @default(false)
  metaTitle       String?      @map("meta_title") @db.Text
  metaKeyword     String?      @map("meta_keyword") @db.Text
  metaDescription String?      @map("meta_description") @db.Text
  ogImagePath     String?      @map("og_image_path") @db.Text
  seoRating       Decimal?     @map("seo_rating") @db.Decimal(2, 1)
  reviewNumber    Int?         @map("review_number")
  bestRating      Decimal?     @map("best_rating") @db.Decimal(2, 1)
  schema          String?      @db.Text
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  category BlogCategory  @relation(fields: [categoryId], references: [id])
  author   User          @relation(fields: [authorId], references: [id])
  contents BlogContent[]
  faqs     BlogFaq[]

  @@map("blogs")
}

model BlogContent {
  id          Int           @id @default(autoincrement())
  title       String
  slug        String
  description String        @db.Text
  imageName   String?       @map("image_name")
  imagePath   String?       @map("image_path") @db.Text
  position    Int           @default(1)
  blogId      Int           @map("blog_id")
  parentId    Int?          @map("parent_id")
  blog        Blog          @relation(fields: [blogId], references: [id], onDelete: Cascade)
  parent      BlogContent?  @relation("BlogContentParent", fields: [parentId], references: [id], onDelete: Cascade)
  children    BlogContent[] @relation("BlogContentParent")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([blogId])
  @@map("blog_contents")
}

model BlogFaq {
  id        Int      @id @default(autoincrement())
  question  String   @db.Text
  answer    String   @db.Text
  position  Int      @default(1)
  status    Boolean  @default(true)
  blogId    Int      @map("blog_id")
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("blog_faqs")
}

// ─────────────────────────────────────────────────────────
// NEWS
// ─────────────────────────────────────────────────────────

model NewsCategory {
  id              Int      @id @default(autoincrement())
  name            String
  slug            String   @unique
  description     String?  @db.Text
  imageName       String?  @map("image_name")
  imagePath       String?  @map("image_path")
  status          Boolean  @default(true)
  metaTitle       String?  @map("meta_title") @db.Text
  metaKeyword     String?  @map("meta_keyword") @db.Text
  metaDescription String?  @map("meta_description") @db.Text
  ogImagePath     String?  @map("og_image_path") @db.Text
  seoRating       Decimal? @map("seo_rating") @db.Decimal(2, 1)
