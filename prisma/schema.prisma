  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("about_us")
}

// ─────────────────────────────────────────────────────────
// ABOUT COUNTRY (Vietnam)
// ─────────────────────────────────────────────────────────

model AboutCountryPage {
  id                      Int      @id @default(autoincrement())
  name                    String
  tagline                 String?
  capital                 String?
  population              String?
  languages               String?
  currency                String?
  location                String?
  timezone                String?
  independenceDay         DateTime? @map("independence_day") @db.Date
  highestPeak             String?  @map("highest_peak")
  highestPeakHeight       String?  @map("highest_peak_height")
  mountainRanges          Json?    @map("mountain_ranges")
  climateZones            Json?    @map("climate_zones")
  topAttractions          Json?    @map("top_attractions")
  ancientSilkRoad         String?  @map("ancient_silk_road") @db.Text
  nomadicHeritage         String?  @map("nomadic_heritage") @db.Text
  religionDiversity       String?  @map("religion_diversity") @db.Text
  culturalHighlights      String?  @map("cultural_highlights") @db.Text
  whoRecognized           Boolean  @default(false) @map("who_recognized")
  mbbsAffordableEducation String?  @map("mbbs_affordable_education") @db.Text
  englishMedium           Boolean  @default(false) @map("english_medium")
  academicExcellence      String?  @map("academic_excellence") @db.Text
  studentLife             String?  @map("student_life") @db.Text
  keySectors              String?  @map("key_sectors") @db.Text
  majorExports            String?  @map("major_exports") @db.Text
  investmentOpportunities String?  @map("investment_opportunities") @db.Text
  gdpGrowth               String?  @map("gdp_growth")
  mainIndustries          String?  @map("main_industries")
  tourismGrowth           String?  @map("tourism_growth")
  hydropowerPotential     String?  @map("hydropower_potential")
  transportation          Json?
  visaConnectivity        String?  @map("visa_connectivity") @db.Text
  publicHealthcare        String?  @map("public_healthcare") @db.Text
  privateHealthcare       String?  @map("private_healthcare") @db.Text
  studentHealthcare       String?  @map("student_healthcare") @db.Text
  nationalSport           String?  @map("national_sport")
  unescoSites             String?  @map("unesco_sites")
  bannerImage             String?  @map("banner_image")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  cuisines         CountryCuisineLifestyle[]
  lifestyles       CountryLifestyleCulture[]
  majorCities      CountryMajorCity[]
  touristAttractions CountryTouristAttraction[]

  @@map("about_country_pages")
}

model CountryCuisineLifestyle {
  id              Int              @id @default(autoincrement())
  dishName        String?          @map("dish_name")
  dishDescription String?          @map("dish_description") @db.Text
  dishImage       String?          @map("dish_image")
  iconClass       String?          @map("icon_class")
  pageId          Int              @map("page_id")
  page            AboutCountryPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("country_cuisine_lifestyles")
}

model CountryLifestyleCulture {
  id          Int              @id @default(autoincrement())
  title       String
  description String?          @db.Text
  iconClass   String?          @map("icon_class") @db.Text
  image       String?          @db.Text
  pageId      Int              @map("page_id")
  page        AboutCountryPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("country_lifestyle_cultures")
}

model CountryMajorCity {
  id          Int              @id @default(autoincrement())
  cityName    String           @map("city_name")
  description String?          @db.Text
  population  String?
  highlights  String?          @db.Text
  cityImage   String?          @map("city_image")
  pageId      Int              @map("page_id")
  page        AboutCountryPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("country_major_cities")
}

model CountryTouristAttraction {
  id             Int              @id @default(autoincrement())
  attractionName String           @map("attraction_name")
  description    String?          @db.Text
  ordering       Int?
  isActive       Boolean          @default(true) @map("is_active")
  image          String?
  iconClass      String?          @map("icon_class")
  pageId         Int              @map("page_id")
  page           AboutCountryPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  @@map("country_tourist_attractions")
}

